#!/usr/bin/env php
<?php

declare(strict_types=1);

// Support both installed-via-composer and standalone invocation.
$autoloadCandidates = [
    __DIR__ . '/../vendor/autoload.php',
    __DIR__ . '/../../vendor/autoload.php',
    __DIR__ . '/../../../autoload.php',
];

$loaded = false;
foreach ($autoloadCandidates as $file) {
    if (file_exists($file)) {
        require_once $file;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    fwrite(STDERR, "Autoloader not found. Run 'composer install' first.\n");
    exit(1);
}

use AIBox\OllamaManager;
use AIBox\OpenWebUIManager;
use AIBox\SystemChecker;

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function writeln(string $line = ''): void
{
    echo $line . PHP_EOL;
}

function heading(string $text): void
{
    $bar = str_repeat('=', strlen($text) + 4);
    writeln();
    writeln($bar);
    writeln("  $text");
    writeln($bar);
}

function printMessages(array $messages): void
{
    foreach ($messages as $msg) {
        writeln("  " . $msg);
    }
}

// ---------------------------------------------------------------------------
// Banner
// ---------------------------------------------------------------------------

writeln('');
writeln('  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—');
writeln(' в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қ');
writeln(' в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв•”в•қ ');
writeln(' в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— ');
writeln(' в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•—');
writeln(' в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қ');
writeln('');
writeln(' Standalone AI Setup Tool');
writeln(' Ollama (llama3.1:8b) + open-webui');
writeln('');

// ---------------------------------------------------------------------------
// Step 1 вҖ“ System capability check
// ---------------------------------------------------------------------------

heading('Step 1/3 вҖ“ System Capability Check');

$checker = new SystemChecker();
$info = $checker->check();

writeln(sprintf('  OS            : %s (%s)', $info['os'], $info['arch']));
writeln(sprintf('  CPU cores     : %d', $info['cpu_cores']));
writeln(sprintf('  RAM           : %d MB', $info['ram_total_mb']));
writeln(sprintf('  Free disk     : %d MB', $info['disk_free_mb']));
writeln(sprintf('  Docker        : %s', $info['docker_available'] ? 'available' : 'NOT available'));
writeln(sprintf('  NVIDIA GPU    : %s', $info['nvidia_gpu'] ? 'detected' : 'not detected'));

if (!empty($info['warnings'])) {
    writeln();
    foreach ($info['warnings'] as $warning) {
        writeln('  ' . $warning);
    }
}

if (!$info['meets_requirements']) {
    writeln();
    writeln('  [FATAL] One or more hard requirements are not met. Aborting.');
    exit(1);
}

writeln();
writeln('  All hard requirements satisfied. ContinuingвҖҰ');

// ---------------------------------------------------------------------------
// Step 2 вҖ“ Ollama
// ---------------------------------------------------------------------------

heading('Step 2/3 вҖ“ Ollama Setup');

$ollamaManager = new OllamaManager();
$ollamaResult = $ollamaManager->setup();
printMessages($ollamaResult['messages']);

if (!$ollamaResult['model_ready']) {
    writeln();
    writeln('  [FATAL] Could not ensure Ollama and the model are ready. Aborting.');
    exit(1);
}

writeln();
writeln(sprintf('  Ollama is serving at %s', OllamaManager::OLLAMA_BASE_URL));
writeln(sprintf('  Model ready   : %s', OllamaManager::DEFAULT_MODEL));

// ---------------------------------------------------------------------------
// Step 3 вҖ“ open-webui
// ---------------------------------------------------------------------------

heading('Step 3/3 вҖ“ open-webui Setup');

$webUI = new OpenWebUIManager();
$uiResult = $webUI->setup();
printMessages($uiResult['messages']);

if (!$uiResult['running']) {
    writeln();
    writeln('  [FATAL] Could not start open-webui. Aborting.');
    exit(1);
}

// ---------------------------------------------------------------------------
// Summary
// ---------------------------------------------------------------------------

heading('Setup Complete');
writeln(sprintf('  open-webui is running at : %s', $uiResult['url']));
writeln(sprintf('  Ollama API               : %s', OllamaManager::OLLAMA_BASE_URL));
writeln(sprintf('  Model loaded             : %s', OllamaManager::DEFAULT_MODEL));
writeln();
writeln('  Open your browser and navigate to ' . $uiResult['url'] . ' to start chatting!');
writeln();
